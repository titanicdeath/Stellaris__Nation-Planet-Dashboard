# Stellaris Nation / Planet Dashboard Parser Settings
# Paths may be absolute or relative to this project directory.

[paths]
stellaris_game_path=D:\SteamLibrary\steamapps\common\Stellaris
save_files_path=save_files
output_path=output
manifest_path=output\manifest.json

[save_selection]
parse_all_save_files=true
# Comma-separated list; used only when parse_all_save_files=false.
specific_save_files=
ignore_autosaves=true
force_reparse=true
# If true, changing settings.config causes already-parsed saves to be parsed again.
reparse_when_settings_change=true
# Default false: gamestate is extracted and parsed in memory only.
retain_extracted_gamestate=false
retained_gamestate_path=output\_extracted_gamestate

[nation_selection]
# parse_all_nations=false means normal political empires only by default.
parse_all_nations=false
player_only=true
# Comma-separated country IDs; used when parse_all_nations=false and player_only=false.
nation_ids=0
nation_name_filter=

[special_nations]
# Collectively enables non-normal/special country objects when parse_all_nations=true.
include_all_special_nations=false
include_fallen_empires=true
include_subjects=true
include_primitives=false
include_enclaves=false
include_crisis=false
include_event_countries=false

[game_definitions]
# Default false. When true, scans common/ definition files and records definition source metadata.
parse_game_definitions=false
include_definition_sources=true

[output]
pretty_json=true
include_raw_ids=true
include_debug_sections=true
include_source_locations=true
include_raw_pdx_objects=false

# Optional compact per-country timeline index for cross-save charting.
export_timeline=true

[debug]
# Default false if omitted. Enable to print per-save and total parser-internal timings.
print_performance_timings=true
# Default false if omitted. Enable to also write output\performance-log.json.
write_performance_log=false
